{
  "name": "slm-neo",
  "version": "0.1.0",
  "description": "The new generation of slm. A modern Slim-like templating engine for Node.js and Deno, featuring native Async/Await support.",
  "type": "module",
  "main": "lib/slm.js",
  "browser": "lib/slm_browser.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "format": "prettier --use-tabs --write lib/ __tests__/"
  },
  "keywords": [
    "html",
    "slm",
    "slim",
    "template",
    "async",
    "await"
  ],
  "author": "colus-img (github.com/colus-img)",
  "contributors": [
    "Yury Korolev (Original slm author)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/colus-img/slm-neo.git"
  },
  "bugs": {
    "url": "https://github.com/colus-img/slm-neo/issues"
  },
  "homepage": "https://github.com/colus-img/slm-neo",
  "devDependencies": {
    "esbuild": "^0.27.4",
    "jest": "^30.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "__tests__/helper.js$"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95.5,
        "functions": 97,
        "lines": 97,
        "statements": 97
      }
    }
  }
}